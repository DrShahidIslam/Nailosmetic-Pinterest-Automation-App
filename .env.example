# ============================================
# Nailosmetic Pinterest Bot — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control!

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- SiliconFlow API ---
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# --- Hugging Face API ---
HUGGINGFACE_API_KEY=your_huggingface_api_token_here

# --- Pinterest API ---
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token_here

# --- Pinterest Board IDs (one per category) ---
PINTEREST_BOARD_AESTHETIC=your_aesthetic_board_id_here
PINTEREST_BOARD_CHROME=your_chrome_board_id_here
PINTEREST_BOARD_MINIMALIST=your_minimalist_board_id_here
PINTEREST_BOARD_SPRING=your_spring_board_id_here
PINTEREST_BOARD_SUMMER=your_summer_board_id_here

# --- Pinterest Token Refresh (Optional but Recommended) ---
# These are needed for automatic token refresh to keep the bot running long-term.
PINTEREST_REFRESH_TOKEN=your_pinterest_refresh_token_here
PINTEREST_APP_ID=your_pinterest_app_id_here
PINTEREST_APP_SECRET=your_pinterest_app_secret_here
